<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FitForge">

        <!-- MainActivity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- WorkoutListActivity -->
        <activity
            android:name=".WorkoutListActivity"
            android:exported="false"
            android:label="Workout History" />

        <!-- LogWorkoutActivity -->
        <activity
            android:name=".LogWorkoutActivity"
            android:exported="false"
            android:label="Log Workout" />

        <!-- ExerciseLibraryActivity -->
        <activity
            android:name=".ExerciseLibraryActivity"
            android:exported="false"
            android:label="Exercise Library" />

        <!-- ProfileActivity -->
        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:label="Profile Settings" />

        <!-- StreakHistoryActivity -->
        <activity
            android:name=".StreakHistoryActivity"
            android:exported="false"
            android:label="Streak History" />

    </application>

</manifest>