<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTimerDisplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1 min 30 sec"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/fit_orange"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnMinus15"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-15s"
            android:backgroundTint="@color/fit_surface"
            android:textColor="@color/fit_text_primary"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btnPlus15"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+15s"
            android:backgroundTint="@color/fit_surface"
            android:textColor="@color/fit_text_primary" />
    </LinearLayout>
</LinearLayout>
