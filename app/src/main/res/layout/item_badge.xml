<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardBadge"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/fit_surface"
    app:cardElevation="4dp">

    <LinearLayout
        android:id="@+id/layoutBadgeContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvEmoji"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:gravity="center"
            android:text="🏅"
            android:textSize="32sp"
            android:background="@drawable/circle_surface_dark_bg"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBadgeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/fit_orange" />

            <TextView
                android:id="@+id/tvBadgeDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/fit_text_secondary"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvHowToGet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="italic"
                android:textColor="@color/fit_text_disabled"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivLockStatus"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_secure"
            app:tint="@color/fit_text_disabled"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
