<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- TextInputLayout Style -->
    <style name="EditTextStyle" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/fit_text_secondary</item>
        <item name="android:inputType">text</item>
    </style>

    <style name="TextInputLayoutStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/dark_surface</item>
        <item name="boxStrokeColor">@color/fit_orange</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/fit_orange</item>
        <item name="android:textColorHint">@color/fit_text_secondary</item>
    </style>

    <!-- Button Styles -->
    <style name="PrimaryButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/fit_orange</item>
        <item name="android:textColor">@color/fit_bg</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="SecondaryButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/fit_surface</item>
        <item name="strokeColor">@color/fit_orange</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/fit_orange</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- CardView Styles -->
    <style name="DarkCardStyle" parent="CardView">
        <item name="cardBackgroundColor">@color/fit_surface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- TextView Styles -->
    <style name="TitleTextStyle">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/fit_orange</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SubtitleTextStyle">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="LabelTextStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="HintTextStyle">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/fit_text_secondary</item>
    </style>

    <style name="CircleImageView">
        <item name="cornerSize">50%</item>
    </style>
</resources>
